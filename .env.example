
# EXCHANGE
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_TESTNET=false
TRADING_PAIR=BTC/USDT:USDT
LEVERAGE=10

# TRADING
TRADING_MODE=paper
STARTING_BALANCE=100
RISK_PER_TRADE=1
MAX_DAILY_LOSS=3
MAX_WEEKLY_LOSS=7
MAX_DRAWDOWN=15
MAX_CONSECUTIVE_LOSSES=5
MAX_OPEN_POSITIONS=3
COOLDOWN_MINUTES=30
MAX_HOLD_HOURS=24

# INDICATORS (OPTIMIZED)
EMA_FAST=30
EMA_SLOW=100
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
ATR_PERIOD=14
ATR_SL_MULTIPLIER=2
ATR_TP_MULTIPLIER=4
SIGNAL_CONFIDENCE_THRESHOLD=35

# RISK (TIGHTER)
BREAK_EVEN_TRIGGER=0.3
TRAILING_STOP_ATR=1.0
PARTIAL_TP_LEVELS=0.8,1.5,3.0
PARTIAL_TP_SIZES=30,30,40

# TIMEFRAMES
TIMEFRAME_PRIMARY=1h
TIMEFRAME_SECONDARY=4h
TIMEFRAME_TERTIARY=15m

# MULTI-PAIR
TRADING_PAIRS=BTC/USDT:USDT,SOL/USDT:USDT,NEAR/USDT:USDT

# AI
AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=cognitivecomputations/dolphin-mistral-24b-venice-edition:free
AI_CONFIDENCE_THRESHOLD=70
AI_MAX_TOKENS=200
AI_TEMPERATURE=0.1

# TELEGRAM
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LOGGING
LOG_LEVEL=info
LOG_MAX_SIZE_MB=50
LOG_MAX_FILES=10
